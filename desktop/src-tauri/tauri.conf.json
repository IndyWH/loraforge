{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LoRAForge",
  "version": "0.1.0",
  "identifier": "dev.loraforge.desktop",
  "build": {
    "frontendDist": "../pages"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LoRAForge",
        "width": 1280,
        "height": 840,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
